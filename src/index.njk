---
layout: base.njk
title: NickKasmo.nl
canonical: /
metaDescription: "NickKasmo.nl is het leven van een maker: bouwen, onderzoeken, experimenteren, falen, leren en doorgaan."
ogDescription: "Het leven van een maker. Eerlijke verhalen over maken, meemaken en doormaken."
needsInstagramEmbed: true
jsonLd:
  "@context": "https://schema.org"
  "@type": "WebSite"
  name: "NickKasmo.nl"
  url: "https://nickkasmo.nl/"
---
<section class="home-hero" aria-labelledby="home-title">
  <div class="home-hero__copy">
    <p class="eyebrow">{{ home.hero.eyebrow }}</p>
    <h1 id="home-title">{{ home.hero.title }}</h1>
    <p>{{ home.hero.intro }}</p>
    <div class="hero__actions">
      <a class="button button--primary" href="#blogs">
        <img src="/assets/icons/book-open.svg" alt="">
        Naar blog
      </a>
      <a class="button button--secondary" href="#videos">
        <img src="/assets/icons/video.svg" alt="">
        Bekijk video's
      </a>
    </div>
  </div>
  <div class="home-hero__pillars" aria-label="Content pijlers">
    {%- for pillar in pillars.list %}
    <a href="/blog/{{ pillar.slug }}/">
      <span>{{ pillar.title }}</span>
      {{ pillar.shortDescription }}
    </a>
    {%- endfor %}
  </div>
</section>

<section class="section featured-section" aria-labelledby="featured-title">
  <article class="featured-card">
    <div class="featured-card__media" aria-hidden="true">
      <div class="image-placeholder">
        <div class="image-placeholder__icons" aria-hidden="true">
          <img src="/assets/icons/coffee.svg" alt="">
          <img src="/assets/icons/book-open.svg" alt="">
          <img src="/assets/icons/sparkles.svg" alt="">
        </div>
      </div>
    </div>
    <div class="featured-card__content">
      <p class="eyebrow">{{ home.featured.eyebrow }}</p>
      <h2 id="featured-title">{{ home.featured.title }}</h2>
      <p class="featured-card__meta">{{ home.featured.meta }}</p>
      <p>{{ home.featured.text }}</p>
      <button class="button button--primary" type="button" data-newsletter-open>
        <img src="/assets/icons/mail.svg" alt="">
        Blijf op de hoogte
      </button>
    </div>
  </article>
</section>

<section class="section about-section" id="wie-is-nick" aria-labelledby="about-title">
  <div class="section__heading">
    <p class="eyebrow">{{ home.about.eyebrow }}</p>
    <h2 id="about-title">{{ home.about.title }}</h2>
  </div>
  <div class="prose-block">
    {%- for paragraph in home.about.paragraphs %}
    <p>{{ paragraph }}</p>
    {%- endfor %}
  </div>
</section>

<section class="section latest-section" id="blogs" aria-labelledby="blogs-title">
  <div class="section__heading section__heading--inline">
    <div>
      <p class="eyebrow">Blog</p>
      <h2 id="blogs-title">Wat ik maak, meemaak en doormaak</h2>
    </div>
    <a class="text-link" href="/blog/">
      Naar blog
      <img src="/assets/icons/arrow-up-right.svg" alt="">
    </a>
  </div>
  <div class="filter-block" aria-labelledby="filter-title">
    <h3 id="filter-title">Verken per pijler</h3>
    <div class="filter-actions" aria-label="Filter artikelen op pijler">
      <button class="button button--primary filter-pill" type="button" data-filter="all">Alles</button>
      {%- for pillar in pillars.list %}
      <button class="button button--secondary filter-pill" type="button" data-filter="{{ pillar.title }}">{{ pillar.title }}</button>
      {%- endfor %}
    </div>
  </div>
  {% if collections.posts.length %}
  <div class="latest-grid">
    {%- for post in collections.posts | limit(4) %}
    {% set postPillar = pillars.list | findPillar(post.data.pillar) %}
    <article class="latest-card post-card" data-pillar="{{ postPillar.title }}">
      <span>{{ postPillar.title }}</span>
      <h3>{{ post.data.title }}</h3>
      <p>{{ post.data.excerpt }}</p>
      <a href="{{ post.url }}">Lees artikel</a>
    </article>
    {%- endfor %}
  </div>
  {% if collections.posts.length > 4 %}
  <button id="load-more-posts" type="button" class="button button--secondary">Meer artikelen</button>
  {% endif %}
  {% else %}
  <div class="latest-grid">
    <article class="latest-card">
      <span>Blog</span>
      <h3>0 artikelen geplaatst</h3>
      <p>Ik toon hier straks alleen stukken die ik zelf heb gepubliceerd.</p>
      <button type="button" data-newsletter-open>Ontvang de eerste update</button>
    </article>
  </div>
  {% endif %}
</section>

<section class="newsletter" id="nieuwsbrief" aria-labelledby="newsletter-title">
  <div>
    <p class="eyebrow">{{ home.newsletter.eyebrow }}</p>
    <h2 id="newsletter-title">{{ home.newsletter.title }}</h2>
    <p>{{ home.newsletter.intro }}</p>
  </div>
  <div class="newsletter-form">
    <span>Inschrijven op nieuwsbrief</span>
    <button type="button" data-newsletter-open>Open aanmeldformulier</button>
    <p>{{ home.newsletter.note }}</p>
  </div>
</section>

<section class="section items-section" id="items" aria-labelledby="items-title">
  <div class="section__heading section__heading--inline">
    <div>
      <p class="eyebrow">Items die ik gebruik</p>
      <h2 id="items-title">Spullen, producten en software uit mijn proces</h2>
    </div>
    <a class="text-link" href="/items/">
      Alles bekijken
      <img src="/assets/icons/arrow-up-right.svg" alt="">
    </a>
  </div>
  <p class="affiliate-note">Sommige links kunnen affiliate links zijn. Als je via zo'n link iets koopt, kan ik daar een kleine vergoeding voor krijgen. Jij betaalt niets extra.</p>
  <div class="item-grid item-grid--preview">
    {%- for item in collections.items | limit(3) %}
    <article class="item-card">
      <div class="item-card__media"><img src="/assets/icons/{{ item.data.icon }}.svg" alt=""></div>
      <div class="item-card__content">
        <div class="tag-list" aria-label="Tags">
          {%- for tag in item.data.itemTags %}
          <span>{{ tag | replace("-", " ") }}</span>
          {%- endfor %}
        </div>
        <h3>{{ item.data.title }}</h3>
        <p>{{ item.templateContent | safe }}</p>
        {% if item.data.affiliateLink %}
        <a class="item-card__action" href="{{ item.data.affiliateLink }}" target="_blank" rel="noreferrer sponsored">Bekijk affiliate link</a>
        {% else %}
        <button type="button" class="item-card__action" disabled>Affiliate link toevoegen</button>
        {% endif %}
      </div>
    </article>
    {%- endfor %}
  </div>
</section>

<section class="section videos-section" id="videos" aria-labelledby="videos-title">
  <div class="section__heading">
    <p class="eyebrow">{{ home.videoIntro.eyebrow }}</p>
    <h2 id="videos-title">{{ home.videoIntro.title }}</h2>
    <p class="section-intro">{{ home.videoIntro.text }}</p>
  </div>

  {%- for group in home.videoGroups %}
  <div class="video-group" id="{{ group.slug }}">
    <div class="section__heading section__heading--inline">
      <div>
        <p class="eyebrow">{{ group.eyebrow }}</p>
        <h3>{{ group.title }}</h3>
      </div>
      <a class="text-link" href="{{ group.linkHref }}" target="_blank" rel="noreferrer">
        {{ group.linkLabel }}
        <img src="/assets/icons/arrow-up-right.svg" alt="">
      </a>
    </div>
    <div class="reels-grid">
      {%- for video in collections.videos | whereGroup(group.slug) %}
      <blockquote class="instagram-media" data-instgrm-captioned data-instgrm-permalink="{{ video.data.permalinkUrl }}" data-instgrm-version="14">
        <a href="{{ video.data.profileUrl }}">Bekijk deze Reel op Instagram</a>
      </blockquote>
      {%- endfor %}
    </div>
  </div>
  {%- endfor %}
</section>

<section class="section gear-section" id="projecten" aria-labelledby="projects-title">
  <div class="section__heading section__heading--inline">
    <div>
      <p class="eyebrow">{{ home.gear.eyebrow }}</p>
      <h2 id="projects-title">{{ home.gear.title }}</h2>
    </div>
    <p class="section-note">{{ home.gear.note }}</p>
  </div>
  <div class="gear-grid">
    {%- for card in home.gear.cards %}
    <article class="gear-card">
      <div class="gear-card__icon"><img src="/assets/icons/{{ card.icon }}.svg" alt=""></div>
      <span>{{ card.label }}</span>
      <h3>{{ card.title }}</h3>
      <p>{{ card.text }}</p>
      <a href="{{ card.linkHref }}">{{ card.linkLabel }}</a>
    </article>
    {%- endfor %}
  </div>
</section>

<section class="section focus-section" id="bezig" aria-labelledby="focus-title">
  <div class="section__heading">
    <p class="eyebrow">{{ home.focus.eyebrow }}</p>
    <h2 id="focus-title">{{ home.focus.title }}</h2>
  </div>
  <div class="focus-grid">
    {%- for card in home.focus.cards %}
    <article class="focus-card">
      <div class="focus-card__icon"><img src="/assets/icons/{{ card.icon }}.svg" alt=""></div>
      <h3>{{ card.title }}</h3>
      {%- for line in card.lines %}
      <p>{{ line }}</p>
      {%- endfor %}
      <a href="{{ card.linkHref }}">{{ card.linkLabel }}</a>
    </article>
    {%- endfor %}
  </div>
</section>

<section class="quote philosophy" aria-labelledby="philosophy-title">
  <p class="eyebrow">{{ home.philosophy.eyebrow }}</p>
  <h2 id="philosophy-title">{{ home.philosophy.title }}</h2>
  <div class="prose-block">
    {%- for paragraph in home.philosophy.paragraphs %}
    <p>{{ paragraph }}</p>
    {%- endfor %}
  </div>
</section>

<section class="follow-section" id="volg" aria-labelledby="follow-title">
  <div>
    <p class="eyebrow">{{ home.follow.eyebrow }}</p>
    <h2 id="follow-title">{{ home.follow.title }}</h2>
    <p>{{ home.follow.text }}</p>
  </div>
  <div class="follow-links">
    <button type="button" data-newsletter-open>Inschrijven op nieuwsbrief</button>
    {%- for social in site.socials %}
    <a href="{{ social.href }}" target="_blank" rel="noreferrer"><img src="/assets/icons/{{ social.icon }}.svg" alt="">{{ social.label }}</a>
    {%- endfor %}
  </div>
</section>

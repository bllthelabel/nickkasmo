<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="{{ metaDescription }}">
    <meta name="theme-color" content="#f4eee6">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="{{ site.url }}{{ canonical }}">
    <meta property="og:locale" content="nl_NL">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="NickKasmo.nl">
    <meta property="og:title" content="{{ ogTitle or title }}">
    <meta property="og:description" content="{{ ogDescription or metaDescription }}">
    <meta property="og:url" content="{{ site.url }}{{ canonical }}">
    <meta property="og:image" content="{{ site.ogImage }}">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ ogTitle or title }}">
    <meta name="twitter:description" content="{{ ogDescription or metaDescription }}">
    <meta name="twitter:image" content="{{ site.ogImage }}">
    <title>{{ title }}</title>
    <link rel="icon" href="/assets/brand/icon.svg" type="image/svg+xml">
    <link rel="stylesheet" href="/styles.css">
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="NickKasmo.nl home">
        <img src="/assets/brand/logo.svg" alt="NickKasmo.nl">
      </a>
      <button class="menu-toggle" type="button" aria-controls="site-nav" aria-expanded="false">
        <span class="menu-toggle__line"></span>
        <span class="menu-toggle__line"></span>
        <span class="menu-toggle__line"></span>
        <span class="visually-hidden">Menu</span>
      </button>
      <nav class="nav" id="site-nav" aria-label="Hoofdnavigatie">
        <a href="/"{% if canonical == "/" %} aria-current="page"{% endif %}>Home</a>
        {%- for item in site.nav %}
        <a href="{{ item.href }}"{% if item.newsletter %} data-newsletter-open{% endif %}{% if item.href == canonical %} aria-current="page"{% endif %}>{{ item.label }}</a>
        {%- endfor %}
      </nav>
    </header>

    <main id="top">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="footer-brand">
        <a class="footer-mark" href="/" aria-label="Naar boven">
          <img src="/assets/brand/logo.svg" alt="NickKasmo.nl">
        </a>
        <div>
          <p class="eyebrow">NickKasmo.nl</p>
          <h2>Het leven van een maker.</h2>
          <p>Ik deel wat ik maak, meemaak en doormaak. Rustig, eerlijk en onderweg.</p>
        </div>
      </div>

      <nav class="footer-nav" aria-label="Footer navigatie">
        {%- for item in site.nav %}
        <a href="{{ item.href }}"{% if item.newsletter %} data-newsletter-open{% endif %}>{{ item.label }}</a>
        {%- endfor %}
      </nav>

      <div class="footer-connect">
        <p class="eyebrow">Loop mee</p>
        <div class="socials" aria-label="Social links">
          {%- for social in site.socials %}
          <a href="{{ social.href }}" target="_blank" rel="noreferrer" aria-label="{{ social.label }}"><img src="/assets/icons/{{ social.icon }}.svg{% if social.iconVersion %}?v={{ social.iconVersion }}{% endif %}" alt=""></a>
          {%- endfor %}
        </div>
        <button class="footer-email-button" type="button" data-contact-open>Stuur een bericht</button>
      </div>

      <div class="footer-bottom">
        <p>&copy; <span id="year"></span> Nick Kasmo. Gemaakt, geleerd en onderweg gedeeld.</p>
      </div>
    </footer>

    <div class="contact-modal" data-contact-modal hidden>
      <div class="contact-modal__backdrop" data-contact-close></div>
      <section class="contact-dialog" role="dialog" aria-modal="true" aria-labelledby="contact-title">
        <button class="contact-dialog__close" type="button" data-contact-close aria-label="Sluit contactformulier">&times;</button>
        <p class="eyebrow">Contact</p>
        <h2 id="contact-title">Waar ben je mee bezig?</h2>
        <p>Stuur me een bericht over een idee, vraag of iets dat je zelf aan het maken bent.</p>
        <form class="contact-form" action="mailto:hallo@nickkasmo.nl" method="post" enctype="text/plain">
          <label for="contact-name">Naam</label>
          <input id="contact-name" name="naam" type="text" autocomplete="name">
          <label for="contact-email">E-mail</label>
          <input id="contact-email" name="email" type="email" autocomplete="email" required>
          <label for="contact-message">Bericht</label>
          <textarea id="contact-message" name="bericht" rows="5" required></textarea>
          <button class="button button--primary" type="submit">Verstuur bericht</button>
        </form>
      </section>
    </div>

    <div class="contact-modal" data-newsletter-modal hidden>
      <div class="contact-modal__backdrop" data-newsletter-close></div>
      <section class="contact-dialog" role="dialog" aria-modal="true" aria-labelledby="newsletter-modal-title">
        <button class="contact-dialog__close" type="button" data-newsletter-close aria-label="Sluit nieuwsbrief formulier">&times;</button>
        <p class="eyebrow">Nieuwsbrief</p>
        <h2 id="newsletter-modal-title">Eerlijk onderweg blijven.</h2>
        <p>Af en toe een verhaal over maken, leren en wat er achter de schermen gebeurt.</p>
        <form class="contact-form newsletter-modal-form">
          <label for="newsletter-modal-email">E-mail</label>
          <input id="newsletter-modal-email" name="email" type="email" autocomplete="email" placeholder="jouw@email.com" required>
          <button class="button button--primary" type="submit">Inschrijven</button>
          <p>Geen hype. Geen perfecte plaatjes. Gewoon wat ik ontdek terwijl ik bezig ben.</p>
        </form>
      </section>
    </div>

    {% if jsonLd %}
    <script type="application/ld+json">
      {{ jsonLd | dump | safe }}
    </script>
    {% endif %}
    <script src="/script.js"></script>
    {% if needsInstagramEmbed %}
    <script async src="https://www.instagram.com/embed.js"></script>
    {% endif %}
  </body>
</html>

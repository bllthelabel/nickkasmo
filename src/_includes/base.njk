<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="{{ metaDescription }}">
    <meta name="theme-color" content="#f4eee6">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="{{ site.url }}{{ canonical }}">
    <meta property="og:locale" content="nl_NL">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="NickKasmo.nl">
    <meta property="og:title" content="{{ ogTitle or title }}">
    <meta property="og:description" content="{{ ogDescription or metaDescription }}">
    <meta property="og:url" content="{{ site.url }}{{ canonical }}">
    <meta property="og:image" content="{{ site.ogImage }}">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ ogTitle or title }}">
    <meta name="twitter:description" content="{{ ogDescription or metaDescription }}">
    <meta name="twitter:image" content="{{ site.ogImage }}">
    <title>{{ title }}</title>
    <link rel="icon" href="/assets/brand/icon.svg" type="image/svg+xml">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Work+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap">
    <link rel="stylesheet" href="/styles.css">
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="NickKasmo.nl home">
        <img src="/assets/brand/logo.svg" alt="NickKasmo.nl">
      </a>
      <button class="menu-toggle" type="button" aria-controls="site-nav" aria-expanded="false">
        <span class="menu-toggle__line"></span>
        <span class="menu-toggle__line"></span>
        <span class="menu-toggle__line"></span>
        <span class="visually-hidden">Menu</span>
      </button>
      <nav class="nav" id="site-nav" aria-label="Hoofdnavigatie">
        {%- for item in site.nav %}
        <a href="{{ item.href }}"{% if item.href == canonical %} aria-current="page"{% endif %}>{{ item.label }}</a>
        {%- endfor %}
      </nav>
    </header>

    <main id="top">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="footer-brand">
        <a class="footer-mark" href="/" aria-label="Naar boven">
          <img src="/assets/brand/logo.svg" alt="NickKasmo.nl">
        </a>
        <div>
          <p class="eyebrow">NickKasmo.nl</p>
          <h2>Onderweg met Nick.</h2>
          <p>Ik deel wat ik onderweg maak, tegenkom en doormaak. Rustig, eerlijk en onderweg.</p>
        </div>
      </div>

      <nav class="footer-nav" aria-label="Footer navigatie">
        {%- for item in site.nav %}
        <a href="{{ item.href }}">{{ item.label }}</a>
        {%- endfor %}
      </nav>

      <div class="footer-connect">
        <p class="eyebrow">Loop mee</p>
        <div class="socials" aria-label="Social links">
          {%- for social in site.socials %}
          <a href="{{ social.href }}" target="_blank" rel="noreferrer" aria-label="{{ social.label }}"><img src="/assets/icons/{{ social.icon }}.svg{% if social.iconVersion %}?v={{ social.iconVersion }}{% endif %}" alt=""></a>
          {%- endfor %}
        </div>
        <a class="footer-email-button" href="/contact/">Stuur een bericht</a>
      </div>

      <div class="footer-bottom">
        <p>&copy; <span id="year"></span> Nick Kasmo. Gemaakt, geleerd en onderweg gedeeld.</p>
      </div>
    </footer>

    <div class="contact-modal" data-newsletter-modal hidden>
      <div class="contact-modal__backdrop" data-newsletter-close></div>
      <section class="contact-dialog" role="dialog" aria-modal="true" aria-labelledby="newsletter-modal-title">
        <button class="contact-dialog__close" type="button" data-newsletter-close aria-label="Sluit nieuwsbrief formulier">&times;</button>
        <p class="eyebrow">Nieuwsbrief</p>
        <h2 id="newsletter-modal-title">Eerlijk onderweg blijven.</h2>
        <p>Af en toe een bericht over wat ik onderweg bouw, tegenkom en leer.</p>
        <form class="contact-form newsletter-modal-form" data-newsletter-form data-endpoint="{{ site.formsWorkerUrl }}/newsletter" data-success-message="Welkom. Je hoort van me zodra ik onderweg weer iets tegenkom.">
          <label for="newsletter-modal-email">E-mail</label>
          <input id="newsletter-modal-email" name="email" type="email" autocomplete="email" placeholder="jouw@email.com" required>
          <div class="form-honeypot" aria-hidden="true">
            <label for="newsletter-modal-website">Website</label>
            <input id="newsletter-modal-website" name="website" type="text" tabindex="-1" autocomplete="off">
          </div>
          <p class="form-error" data-form-error role="alert"></p>
          <button class="button button--primary" type="submit">Inschrijven</button>
          <p>Geen hype. Geen mooie vakantiefoto's. Gewoon wat ik onderweg tegenkom.</p>
          <p class="form-success" data-form-success role="status"></p>
        </form>
      </section>
    </div>

    {% if jsonLd %}
    <script type="application/ld+json">
      {{ jsonLd | dump | safe }}
    </script>
    {% endif %}
    <script src="/script.js"></script>
    {% if needsInstagramEmbed %}
    <script async src="https://www.instagram.com/embed.js"></script>
    {% endif %}
  </body>
</html>

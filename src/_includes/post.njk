---
layout: base.njk
---
{% set pillarData = pillars.list | findPillar(pillar) %}
<section class="blog-hero">
  <a class="back-link" href="/blog/{{ pillar }}/">Terug naar {{ pillarData.title }}</a>
  <p class="eyebrow">{{ pillarData.title }}</p>
  <h1>{{ title }}</h1>
  <p>{{ date | dutchDate }}</p>
</section>

<section class="section blog-post-body">
  <div class="prose-block">
    {{ content | safe }}
  </div>
  <a class="text-link" href="/blog/{{ pillar }}/">
    Terug naar {{ pillarData.title }}
    <img src="/assets/icons/arrow-up-right.svg" alt="">
  </a>
</section>
